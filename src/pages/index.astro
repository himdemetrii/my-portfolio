---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Demetri Williams — CS Portfolio',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'LinkedIn',
        href: 'https://www.linkedin.com/in/demetri-williams-0370aa304/',
        target: '_blank',
        icon: 'tabler:brand-linkedin',
      },
      { text: 'View Projects', href: '#projects' },
    ]}
  >
    <Fragment slot="title">
      Hi, I'm <span class="text-accent dark:text-white">Demetri Williams</span>
    </Fragment>

    <Fragment slot="subtitle">
      Computer Science student at LSU specializing in Software Engineering and AI.
      I build intelligent systems, full-stack applications, and document everything along the way.
    </Fragment>

    <Fragment slot="image">
      <div class="flex justify-center">
        <video
          src="/intro-video.mp4"
          autoplay
          muted
          loop
          playsinline
          controls
          class="rounded-xl shadow-lg max-w-sm w-full"
        />
      </div>
    </Fragment>
  </Hero>

  <!-- Skills -->
  <Features
    id="skills"
    tagline="What I Work With"
    title="Skills & Technologies"
    subtitle="A blend of AI/ML knowledge, full-stack development, and data analysis built through coursework, projects, and real-world experience!"
    items={[
      {
        title: 'AI & Machine Learning',
        description: 'Reinforcement learning, neural networks, model training & fine-tuning, LLMs, PyTorch, and working with real-world datasets.',
        icon: 'tabler:brain',
      },
      {
        title: 'Full-Stack Development',
        description: 'Python (Flask), JavaScript, HTML/CSS, Firebase, REST APIs, and building end-to-end web applications.',
        icon: 'tabler:code',
      },
      {
        title: 'Data & Analytics',
        description: 'SQL, data analysis, reporting, dashboards, Google Analytics, and translating raw data into actionable insights.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Cloud & DevOps',
        description: 'AWS, Google Cloud, Azure, Linux, Bash scripting, and cloud infrastructure fundamentals.',
        icon: 'tabler:cloud',
      },
      {
        title: 'Programming Languages',
        description: 'Python, Java, C, C++, C#, SQL, JavaScript, Bash — comfortable across multiple paradigms.',
        icon: 'tabler:terminal-2',
      },
      {
        title: 'Design & Collaboration',
        description: 'Figma, hi-fi/lo-fi UI/UX design, Scrum, cross-functional teamwork, and technical documentation.',
        icon: 'tabler:layout',
      },
    ]}
  />

  <!-- Experience -->
  <Steps
    title="Experience"
    items={[
      {
        title: 'AI Trainer / QA Analyst — <span class="font-medium">TELUS Digital</span> <span class="text-sm text-gray-500">(July 2025 – Sept 2025)</span>',
        description:
          'Trained image recognition models by reviewing large-scale datasets and correcting classifications. Performed diagnostic analysis to reduce misclassification rates and documented training outcomes via detailed reports.',
        icon: 'tabler:robot',
      },
      {
        title: 'AI Training Specialist — <span class="font-medium">Outlier AI</span> <span class="text-sm text-gray-500">(May 2024 – Dec 2024)</span>',
        description:
          'Reviewed and evaluated AI model outputs daily, led root cause analysis on errors, and fine-tuned models using real-world feedback loops. Collaborated internationally and prepared detailed data reports for engineering teams.',
        icon: 'tabler:sparkles',
      },
      {
        title: 'B.S. Computer Science Engineering — <span class="font-medium">LSU</span> <span class="text-sm text-gray-500">(Expected December 2026)</span>',
        description:
          "Concentration in Software Engineering. GPA: 3.25. Dean's List 2025. Coursework includes AI, Database Systems, Cloud Computing, Programming Languages, Operating Systems, and Advanced Data Structures.",
        icon: 'tabler:school',
      },
    ]}
    image={{
      src: '~/assets/images/coverphoto.jpeg',
      alt: 'Work experience',
    }}
  />

  <!-- Projects -->
  <Content
    id="projects"
    isReversed
    tagline="Projects"
    title="What I've Built - So Far ;)"
    items={[
      {
        title: 'Reinforcement Learning',
        description: 'Built using PyTorch and Google DeepMind\'s Open Spiel framework, optimizing strategy in limited-information environments.',
      },
      {
        title: 'Neural Network Architecture',
        description: 'Implemented dense input layers, multi-action output heads, and SoftMax activation — improving accuracy from 0% to 64%.',
      },
      {
        title: 'Performance Analysis',
        description: 'Bot survived 37 hands against peer-designed bots. Compiled a full engineering report with analytics, trends, and findings.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1511193311914-0346f16efe90?auto=format&fit=crop&w=2070&q=80',
      alt: 'Poker Bot Project',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Texas Hold 'Em Poker Bot</h3>
      A reinforcement learning AI bot trained to play poker using PyTorch and DeepMind's Open Spiel framework.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Content
    isAfterContent
    items={[
      {
        title: 'Full-Stack Application',
        description: 'Python (Flask) backend with Steam OpenID login, achievement fetching, and Firebase database logic.',
      },
      {
        title: 'Gamified Features',
        description: 'Tracks streaks, manages friend connections, and ranks users competitively through leaderboards and dashboards.',
      },
      {
        title: 'Responsive Frontend',
        description: 'Built with HTML, CSS, and JavaScript — monitoring user engagement, system uptime, and performance metrics.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1542751371-adc38448a05e?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Steam Achievement Fetcher',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Steam Achievement Fetcher</h3>
      A full-stack web app integrating with the Steam API to generate random achievement challenges with social and gamified features.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Stats -->
  <Stats
    stats={[
      { title: 'TikTok Followers', amount: '34K+' },
      { title: 'GPA', amount: '3.25' },
      { title: "Dean's List", amount: '2025' },
      { title: 'Projects Built', amount: '4+' },
    ]}
  />

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Connect on LinkedIn',
        href: 'https://www.linkedin.com/in/demetri-williams-0370aa304/',
        target: '_blank',
        icon: 'tabler:brand-linkedin',
      },
    ]}
  >
    <Fragment slot="title">
      Let's Connect!
    </Fragment>
    <Fragment slot="subtitle">
      Open to internships, collaborations, and new opportunities. Feel free to reach out!
    </Fragment>
  </CallToAction>

</Layout>